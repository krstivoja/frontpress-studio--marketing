<!-- ──────────────── 01 HERO ──────────────── -->
<section class="hero" id="top">
  <div class="hero__grid"></div>
  <div class="hero__bg" aria-hidden="true">
    <svg viewBox="0 0 1600 900" preserveAspectRatio="xMidYMid slice">
      <defs>
        <radialGradient id="g1" cx="80%" cy="20%" r="60%">
          <stop offset="0" stop-color="#A8C7D4" stop-opacity="0.16"></stop>
          <stop offset="1" stop-color="#A8C7D4" stop-opacity="0"></stop>
        </radialGradient>
        <radialGradient id="g2" cx="10%" cy="90%" r="60%">
          <stop offset="0" stop-color="#142340" stop-opacity="0.9"></stop>
          <stop offset="1" stop-color="#0B1228" stop-opacity="0"></stop>
        </radialGradient>
      </defs>
      <rect width="1600" height="900" fill="url(#g1)"></rect>
      <rect width="1600" height="900" fill="url(#g2)"></rect>
      <!-- subtle horizontal frequency lines -->
      <g stroke="#A8C7D4" stroke-width="0.6" fill="none" opacity="0.18">
        <path d="M0,720 Q400,710 800,720 T1600,720"></path>
        <path d="M0,750 Q400,738 800,750 T1600,750"></path>
        <path d="M0,780 Q400,768 800,780 T1600,780"></path>
        <path d="M0,810 Q400,798 800,810 T1600,810"></path>
        <path d="M0,840 Q400,828 800,840 T1600,840"></path>
      </g>
    </svg>
  </div>

  <div class="wrap hero__inner">
    <div class="hero__meta">
      <span class="chip">Edition 03 · January 2027</span>
      <span class="edition">Three days · Three themes · One programme</span>
    </div>

    <h1 class="hero__wordmark">
      <span class="hero__mark-row" style="display:flex; align-items:center; gap:24px; margin-bottom:18px;">
        <span class="id-logo__mark" style="--id-size:88px; color:var(--ice); border-width:2px;"></span>
        <span style="display:flex; flex-direction:column; gap:6px; font-family:'Space Mono', monospace; font-size:11px; letter-spacing:0.22em; text-transform:uppercase; color:var(--muted-light); line-height:1.5; font-weight:400;">
          <span>21 — 23 January 2027</span>
          <span style="height:1px; width:48px; background:var(--ice); opacity:0.6;"></span>
          <span>Villa Beaulieu · St. Moritz</span>
        </span>
      </span>
      <span>Industry</span><br>
      <span class="days">Days</span>
    </h1>

    <div class="hero__endorse">
      <span>an event by</span>
      <img src="/uploads/cfc-logo-white.png" alt="CfC St. Moritz" style="height:64px;">
      <span style="display:flex; flex-direction:column; gap:2px; font-size:11px; opacity:0.78;">
        <span>CURATED SINCE 2018</span>
        <span style="color:var(--ice); letter-spacing:0.18em;">By invitation · Engadin</span>
      </span>
    </div>

    <div class="hero__lower">
      <div>
        <p class="hero__tagline">
          Where DeepTech meets <em>real world adoption</em>.<br>
          Curated, not crowded. No hype, just what actually works.
        </p>
        <div class="hero__cta-row">
          <a class="btn btn--primary" href="#apply">Request invitation</a>
          <a class="btn btn--ghost" href="#deeptech">See programme</a>
        </div>
      </div>
      <dl class="hero__facts">
        <div>
          <dt>When</dt>
          <dd>21 to 23 January 2027</dd>
        </div>
        <div>
          <dt>Where</dt>
          <dd>Villa Beaulieu<br>St. Moritz, Switzerland</dd>
        </div>
        <div>
          <dt>Format</dt>
          <dd>By application</dd>
        </div>
        <div>
          <dt>Edition</dt>
          <dd>03 · 2027</dd>
        </div>
      </dl>
    </div>
  </div>
</section>
